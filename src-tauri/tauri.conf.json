            {
                "ext": ["mp3"],
                "name": "MP3 Audio File",
                "description": "MP3 audio file playable in Monochrome+",
                "mimeType": "audio/mpeg",
                "role": "Viewer"
            },
            {
                "ext": ["flac"],
                "name": "FLAC Audio File",
                "description": "FLAC lossless audio file playable in Monochrome+",
                "mimeType": "audio/flac",
                "role": "Viewer"
            },
            {
                "ext": ["wav"],
                "name": "WAV Audio File",
                "description": "WAV audio file playable in Monochrome+",
                "mimeType": "audio/wav",
                "role": "Viewer"
            },
            {
                "ext": ["m4a", "aac"],
                "name": "AAC Audio File",
                "description": "AAC audio file playable in Monochrome+",
                "mimeType": "audio/aac",
                "role": "Viewer"
            },
            {
                "ext": ["ogg"],
