{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Monochrome+",
    "version": "2.0.0",
    "identifier": "network.appwrite.monochromeplus",
    "build": {
        "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
        "beforeBuildCommand": "npm run build:web",
        "devUrl": "http://127.0.0.1:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Monochrome+",
                "width": 1440,
                "height": 900,
                "minWidth": 480,
                "minHeight": 320,
                "maxWidth": 1920,
                "maxHeight": 1200,
                "decorations": true,
                "resizable": true,
                "fullscreen": false,
                "maximizable": true,
                "minimizable": true,
                "closable": true,
                "dragDropEnabled": true,
                "focus": true,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": null,
            "capabilities": ["default"]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "category": "Music",
        "shortDescription": "Monochrome+ Desktop",
        "longDescription": "Hyper-fast, privacy-respecting, high-fidelity desktop music experience.",
        "createUpdaterArtifacts": true,
        "externalBin": [],
        "publisher": "Monochrome",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "../public/assets/appicon.png"
        ],
        "macOS": {
            "minimumSystemVersion": "10.15"
        }
    },
    "plugins": {
        "updater": {
            "active": true,
            "dangerousInsecureTransportProtocol": false,
            "endpoints": ["https://github.com/monochrome-music/monochrome/releases/latest/download/latest.json"],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMzVEMTE5NEIzQjAzQUIKUldTckF6dExHZEUxSU0rbWVtRWFUNE8xbVlTVEV5SlRmempRNGV4aVlteENrVy9kK1BpZS9STHMK"
        }
    }
}
