{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Monochrome+",
    "version": "1.0.3",
    "identifier": "network.appwrite.monochromeplus",
    "build": {
        "beforeDevCommand": "node -e \"console.log('Using hosted Monochrome+ frontend for Tauri dev')\"",
        "beforeBuildCommand": "node -e \"console.log('Using hosted Monochrome+ frontend for Tauri build')\"",
        "devUrl": "https://monochrome-plus.appwrite.network",
        "frontendDist": "https://monochrome-plus.appwrite.network"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Monochrome+",
                "url": "https://monochrome-plus.appwrite.network",
                "width": 1440,
                "height": 900,
                "minWidth": 480,
                "minHeight": 320,
                "decorations": false,
                "resizable": true,
                "fullscreen": false,
                "maximizable": true,
                "minimizable": true,
                "closable": true,
                "dragDropEnabled": true,
                "focus": true,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": null,
            "capabilities": ["default"]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "category": "Music",
        "shortDescription": "Monochrome+ Desktop",
        "longDescription": "Hyper-fast, privacy-respecting, high-fidelity desktop music experience.",
        "createUpdaterArtifacts": true,
        "externalBin": [],
        "publisher": "Monochrome",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "../public/assets/appicon.png"
        ],
        "macOS": {
            "minimumSystemVersion": "10.15"
        }
    },
    "plugins": {
        "updater": {
            "active": true,
            "dangerousInsecureTransportProtocol": false,
            "endpoints": ["https://github.com/itsmeadarsh2008/monochrome-plus/releases/latest/download/latest.json"],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMzVEMTE5NEIzQjAzQUIKUldTckF6dExHZEUxSU0rbWVtRWFUNE8xbVlTVEV5SlRmempRNGV4aVlteENrVy9kK1BpZS9STHMK"
        }
    }
}
