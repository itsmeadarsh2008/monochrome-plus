{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Monochrome+",
    "version": "2.0.9",
    "identifier": "app.monochrome.plus",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Monochrome+",
                "width": 1280,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "visible": true,
                "transparent": false,
                "decorations": false,
                "center": true,
                "shadow": true
            }
        ],
        "security": {
            "csp": null
        },
        "trayIcon": {
            "iconPath": "icons/32x32.png",
            "title": "Monochrome+",
            "tooltip": "Monochrome+ - High-fidelity music streaming"
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": ["appimage", "nsis", "dmg", "app"],
        "publisher": "Monochrome+ Team",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": "http://timestamp.digicert.com",
            "webviewInstallMode": {
                "type": "embedBootstrapper"
            },
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "installDisplayName": "Monochrome+",
                "languages": ["English"],
                "displayLanguageSelector": false,
                "installMode": "both",
                "startMenuFolder": "Monochrome+"
            },
            "wix": {
                "language": ["en-US"],
                "upgradeCode": "B5C7A3F2-1D4E-4B8A-9E2C-8F6A3D5B7E1A"
            }
        },
        "macOS": {
            "frameworks": [],
            "minimumSystemVersion": "10.13",
            "signingIdentity": null,
            "entitlements": null,
            "exceptionDomain": null
        },
        "linux": {
            "appimage": {
                "bundleMediaFramework": false
            },
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0"
                ]
            }
        },
        "android": {
            "minSdkVersion": 21
        },
        "iOS": {
            "developmentTeam": null,
            "minimumSystemVersion": "13.0"
        },
        "resources": [],
        "copyright": "Copyright (c) 2026 Monochrome+ Team",
        "category": "Music",
        "shortDescription": "High-fidelity music streaming",
        "longDescription": "Monochrome+ is a privacy-respecting, high-fidelity music streaming application built for focused listening.",
        "fileAssociations": [
            {
                "ext": ["mp3"],
                "name": "MP3 Audio File",
                "mimeType": "audio/mpeg",
                "role": "Viewer"
            },
            {
                "ext": ["flac"],
                "name": "FLAC Audio File",
                "mimeType": "audio/flac",
                "role": "Viewer"
            },
            {
                "ext": ["wav"],
                "name": "WAV Audio File",
                "mimeType": "audio/wav",
                "role": "Viewer"
            },
            {
                "ext": ["m4a", "aac"],
                "name": "AAC Audio File",
                "mimeType": "audio/aac",
                "role": "Viewer"
            },
            {
                "ext": ["ogg"],
                "name": "OGG Audio File",
                "mimeType": "audio/ogg",
                "role": "Viewer"
            },
            {
                "ext": ["opus"],
                "name": "Opus Audio File",
                "mimeType": "audio/opus",
                "role": "Viewer"
            }
        ]
    },
    "plugins": {
        "updater": {
            "active": true,
            "dialog": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyRjQxNjIwMEY1RTQwNTUKUldTbndGZ1FKcFl3VXh2SjRDMG5POUJiRG0wbmZrMlFQMUUxY0tNQUY5eGxVdW1VNjdBVUxGZ0MK",
            "endpoints": [
                "https://github.com/itsmeadarsh2008/monochrome-plus/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
